{
  "name": "tipea-ws-functions",
  "description": "Cloud Functions for tipea-ws",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "axios": "^1.15.2",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.2",
    "nodemailer": "^8.0.4",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "private": true
}
